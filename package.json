{
  "name": "likhaverse",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "dev:web": "cd apps/web && npm run dev",
    "build:web": "cd apps/web && npm run build",
    "dev:gateway": "cd services/api-gateway && npm run start:dev",
    "dev:auth": "cd services/auth-service && npm run start:dev",
    "dev:user": "cd services/user-service && npm run start:dev",
    "dev:story": "cd services/story-service && npm run start:dev",
    "dev:episode": "cd services/episode-service && npm run start:dev",
    "dev:access": "cd services/access-service && npm run start:dev",
    "dev:payment": "cd services/payment-service && npm run start:dev",
    "dev:notification": "cd services/notification-service && npm run start:dev",
    "dev:all": "concurrently \"npm run dev:gateway\" \"npm run dev:auth\" \"npm run dev:user\" \"npm run dev:story\" \"npm run dev:episode\" \"npm run dev:access\" \"npm run dev:payment\" \"npm run dev:notification\"",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:prod:up": "docker compose -f docker-compose.prod.yml up -d",
    "docker:prod:down": "docker compose -f docker-compose.prod.yml down",
    "db:push": "npx prisma db push",
    "db:generate": "npx prisma generate",
    "db:studio": "npx prisma studio",
    "backup": "bash scripts/backup.sh",
    "restore": "bash scripts/restore.sh",
    "worker": "tsx src/lib/queue/worker-entry.ts"
  },
  "devDependencies": {
    "@types/nodemailer": "^8.0.1",
    "concurrently": "^9.0.0",
    "prisma": "^7.8.0",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "@libsql/client": "^0.17.4",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sentry/nextjs": "^10.63.0",
    "@tailwindcss/postcss": "^4.3.2",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.79.2",
    "enhanced-resolve": "^5.24.2",
    "eventemitter3": "^5.0.4",
    "firebase": "^12.15.0",
    "firebase-admin": "^14.1.0",
    "ioredis": "^5.11.1",
    "lucide-react": "^1.23.0",
    "next-auth": "^4.24.14",
    "nodemailer": "^7.0.13",
    "openai": "^6.45.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "replicate": "^1.4.0",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.2",
    "uuid": "^14.0.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  }
}
